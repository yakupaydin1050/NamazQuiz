{
  "expo": {
    "name": "NamazQuiz",
    "slug": "NamazQuiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "namazquiz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.yaay.namazquiz",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#161616",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçmek için galeri erişimi gerekiyor.",
          "cameraPermission": "Profil fotoğrafı çekmek için kamera erişimi gerekiyor."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#161616",
          "dark": {
            "backgroundColor": "#161616"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "51946ad5-4650-4894-9335-a3609c2bf108"
      }
    }
  }
}
